
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<title>Einlagenrückgewähr · Prüfung</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Spectral:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
:root{
  --ink:#1C2B26; --ink2:#33463F; --papier:#F6F7F4; --karte:#FFFFFF;
  --linie:#DDE1DA; --gold:#8C6A2F; --grau1:#4B554F; --grau2:#8B948D;
  --ok:#00B37E; --warn:#E8A317; --rot:#E5484D; --radius:10px;
}
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
html,body{height:100%}
body{background:var(--papier);color:var(--ink);font-family:'Spectral',Georgia,serif;font-size:16px;line-height:1.55;display:flex;justify-content:center}
.app{width:100%;max-width:480px;min-height:100dvh;display:flex;flex-direction:column;position:relative}
.seitenleiste{display:none}

.topbar{display:flex;align-items:center;gap:.8rem;padding:1rem 1.25rem .6rem;position:sticky;top:0;background:var(--papier);z-index:5}
.zurueck{width:38px;height:38px;border-radius:6px;border:1px solid var(--linie);background:var(--karte);font-size:1.05rem;cursor:pointer;color:var(--ink);display:flex;align-items:center;justify-content:center;flex-shrink:0;font-family:'Inter',sans-serif}
.zurueck:disabled{opacity:.35;cursor:default}
.progress{flex:1;height:3px;background:#E3E7E1;border-radius:2px;overflow:hidden}
.progress i{display:block;height:100%;width:0;background:var(--ink);border-radius:2px;transition:width .4s cubic-bezier(.4,0,.2,1)}
.schritt-nr{font-family:'Inter',sans-serif;font-size:.72rem;font-weight:600;color:var(--grau2);min-width:2.6rem;text-align:right}

.screens{flex:1;position:relative;overflow:hidden}
.screen{position:absolute;inset:0;padding:1.2rem 1.25rem 2rem;display:flex;flex-direction:column;overflow-y:auto;opacity:0;transform:translateX(28px);pointer-events:none;transition:opacity .3s,transform .3s}
.screen.aktiv{opacity:1;transform:none;pointer-events:auto}
.screen.raus{transform:translateX(-28px)}

.tag{display:inline-flex;align-self:flex-start;font-family:'Inter',sans-serif;font-size:.7rem;font-weight:700;letter-spacing:.18em;text-transform:uppercase;color:var(--gold);margin-bottom:.9rem}
h1{font-family:'Spectral',serif;font-size:1.55rem;font-weight:700;line-height:1.22;margin-bottom:.5rem;color:var(--ink)}
.sub{color:var(--grau1);font-size:.92rem;margin-bottom:1.5rem}

.optionen{display:flex;flex-direction:column;gap:.6rem}
.opt{display:flex;align-items:center;gap:.85rem;width:100%;text-align:left;background:var(--karte);border:1px solid var(--linie);border-radius:var(--radius);padding:.95rem 1rem;cursor:pointer;font-family:'Spectral',serif;font-size:.98rem;font-weight:600;color:var(--ink);transition:border-color .15s,background .15s,transform .1s}
.opt:active{transform:scale(.99)}
.opt.gewaehlt{border-color:var(--ink);background:#EDF1EC;box-shadow:inset 3px 0 0 var(--ink)}
.opt .icon{width:38px;height:38px;border-radius:9px;background:#EDF1EC;display:flex;align-items:center;justify-content:center;font-size:1.1rem;flex-shrink:0}
.opt.gewaehlt .icon{background:var(--ink)}
.opt small{display:block;font-family:'Inter',sans-serif;font-weight:400;color:#6B756E;font-size:.78rem;margin-top:.15rem;line-height:1.4}

.info-row{margin-top:auto;padding-top:1.4rem}
details{border-top:1px solid var(--linie)}
details summary{list-style:none;display:flex;align-items:center;justify-content:space-between;padding:.9rem 0;cursor:pointer;font-family:'Inter',sans-serif;font-size:.83rem;font-weight:600;color:#5A645D}
details summary::after{content:"⌄";transition:transform .2s;color:var(--grau2)}
details[open] summary::after{transform:rotate(180deg)}
details .inhalt{padding:0 0 1rem;font-family:'Inter',sans-serif;font-size:.8rem;color:var(--grau1);line-height:1.55}

.hero-zahl{text-align:center;padding:1.2rem 0 .4rem}
.status-dot{width:64px;height:64px;border-radius:14px;margin:0 auto 1rem;display:flex;align-items:center;justify-content:center;font-size:1.7rem;color:#fff;font-family:'Inter',sans-serif}
.status-dot.gruen{background:var(--ok)}.status-dot.gelb{background:var(--warn)}.status-dot.rotf{background:var(--rot)}.status-dot.neutral{background:var(--grau2)}
.risiko{display:flex;justify-content:space-between;align-items:center;background:var(--karte);border:1px solid var(--linie);border-radius:var(--radius);padding:1rem 1.1rem;margin:1.3rem 0 .5rem;font-family:'Inter',sans-serif}
.risiko b{font-size:.88rem}
.risiko .wert{font-weight:800;font-size:.95rem;text-align:right}
.wert.gruen{color:var(--ok)}.wert.gelb{color:var(--warn)}.wert.rotf{color:var(--rot)}
.liste .zeile{display:flex;gap:.9rem;padding:.95rem 0;border-bottom:1px solid var(--linie);font-size:.88rem}
.liste .punkt{width:34px;height:34px;border-radius:9px;background:#EDF1EC;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:1rem}
.liste b{display:block;font-family:'Spectral',serif;font-size:.9rem;color:var(--ink)}
.liste span{font-family:'Inter',sans-serif;color:#5A645D;font-size:.8rem;line-height:1.45}

.cta-bereich{position:sticky;bottom:0;background:linear-gradient(transparent,var(--papier) 30%);padding:1.4rem 0 max(1rem,env(safe-area-inset-bottom))}
.cta{width:100%;border:1px solid var(--ink);background:var(--ink);color:#fff;font-family:'Inter',sans-serif;font-weight:700;font-size:.95rem;padding:1rem;border-radius:8px;cursor:pointer}
.cta.ghost{background:var(--karte);border:1px solid var(--linie);color:var(--ink);margin-top:.6rem}
.disclaimer{font-family:'Inter',sans-serif;font-size:.7rem;color:var(--grau2);text-align:center;padding:.8rem 1.5rem 0;line-height:1.5}

#druckbericht{display:none}
@media print{
  @page{size:A4;margin:14mm 16mm}
  body{display:block !important;background:#fff !important;font-family:'Inter',sans-serif;color:#0E0E0F;-webkit-print-color-adjust:exact}
  .app{display:none !important}
  #druckbericht{display:block !important;font-size:9.5pt}
  .db-kopf{display:flex;justify-content:space-between;margin-bottom:7mm}
  .db-hero{border-radius:4mm;padding:7mm;margin-bottom:6mm;color:#fff}
  .db-hero.gruen{background:#00B37E}.db-hero.gelb{background:#E8A317}.db-hero.rotf{background:#E5484D}
  .db-zeile{display:flex;justify-content:space-between;padding:2.2mm 0;border-bottom:.4pt solid #ECECEE}
  .db-folge{padding:1.8mm 0;border-bottom:.4pt solid #ECECEE}
  .db-fusz{margin-top:5mm;padding-top:3mm;border-top:.4pt solid #ECECEE;font-size:6.5pt;color:#A9A9AE}
}
</style>
</head>
<body>
<div class="app">
  <div class="topbar">
    <button class="zurueck" id="btn-zurueck" disabled>←</button>
    <div class="progress"><i id="fortschritt"></i></div>
    <div class="schritt-nr" id="schritt-nr"></div>
  </div>
  <div class="screens" id="screens"></div>
  <p class="disclaimer">Strukturierte Prüfung · Keine Rechtsberatung</p>
</div>
<div id="druckbericht"></div>

<script>
const FRAGEN = [
 {id:"F1", nr:1, tag:"Schritt 1", titel:"Rechtsform", sub:"Welche Gesellschaft?", optionen:[{w:"gmbh", label:"GmbH"},{w:"ag", label:"AG"},{w:"gmbhcokg", label:"GmbH & Co KG"},{w:"andere", label:"Andere"}], quelle:"§ 82 GmbHG"},
 {id:"F2", nr:2, tag:"Schritt 2", titel:"Empfänger", sub:"Wem kommt die Leistung zugute?", optionen:[{w:"gesellschafter", label:"Gesellschafter"},{w:"dritter", label:"Echter Dritter"}], quelle:"OGH Judikatur"},
 {id:"F3", nr:3, tag:"Schritt 3", titel:"Art der Leistung", sub:"Welche Zuwendung?", optionen:[{w:"sicherheit", label:"Sicherheit"},{w:"geld", label:"Geldleistung"},{w:"nein", label:"Keine"}], quelle:"OGH 6 Ob 14/14y"},
 {id:"S1", nr:4, tag:"Sicherheiten", titel:"Sicherungszweck", sub:"Wessen Schuld?", optionen:[{w:"eigene", label:"Eigene"},{w:"gesellschafter", label:"Gesellschafter"}], quelle:"OGH 6 Ob 14/14y"},
 {id:"S2", nr:5, tag:"Sicherheiten", titel:"Fremdüblichkeit", sub:"Ist die Sicherheit fremdüblich?", optionen:[{w:"ja", label:"Ja"},{w:"nein", label:"Nein"}], quelle:"OGH 6 Ob 14/14y"}
];

const FOLGEN_ALLGEMEIN = [{b:"Nichtigkeit", s:"Gem. § 879 ABGB."}, {b:"Rückersatz", s:"Gem. § 83 GmbHG."}];
const FOLGEN_SICHERHEIT = [{b:"Nichtigkeit", s:"Sicherheitenbestellung nichtig."}, {b:"Bank", s:"Wirkung auch gegen Bank."}];

const antworten = {};
let pfad = ["F1"];
let letztesErgebnis = null;

function auswerten(){
  const a = antworten;
  if(a.F2==="dritter" || a.F3==="nein" || a.S1==="eigene") return {typ:"gruen", emoji:"✓", risiko:"Niedrig", titel:"Kein Verstoß", text:"Keine Einlagenrückgewähr.", folgen:null};
  if(a.S2==="ja") return {typ:"gruen", emoji:"✓", risiko:"Niedrig", titel:"Fremdüblich", text:"Sicherheit hält Drittvergleich stand.", folgen:null};
  return {typ:"rotf", emoji:"✕", risiko:"Hoch", titel:"Verbotene Einlagenrückgewähr", text:"Verstoß gegen Kapitalerhaltung.", folgen:a.F3==="sicherheit"?"sicherheit":"allgemein"};
}

function naechsteFrageId(id, w){
  if(id==="F1") return "F2";
  if(id==="F2") return w==="dritter" ? null : "F3";
  if(id==="F3") return w==="sicherheit" ? "S1" : null;
  if(id==="S1") return w==="eigene" ? null : "S2";
  return null;
}

const wrap = document.getElementById("screens");
FRAGEN.forEach(f=>{
  const s = document.createElement("div");
  s.className = "screen"; s.dataset.fid = f.id;
  s.innerHTML = `<h1>${f.titel}</h1><div class="optionen">${f.optionen.map(o=>`<button class="opt" data-wert="${o.w}">${o.label}</button>`).join("")}</div>`;
  s.querySelectorAll(".opt").forEach(btn=>btn.addEventListener("click",()=>{
    antworten[f.id] = btn.dataset.wert;
    weiter(f.id, btn.dataset.wert);
  }));
  wrap.appendChild(s);
});

function weiter(id, w){
  const n = naechsteFrageId(id, w);
  if(!n){ letztesErgebnis = auswerten(); zeigeErgebnis(); } else { pfad.push(n); zeige(n); }
}

function zeige(id){
  document.querySelectorAll(".screen").forEach(s=>s.classList.remove("aktiv"));
  document.querySelector(`[data-fid="${id}"]`).classList.add("aktiv");
}

function zeigeErgebnis(){
  const erg = letztesErgebnis;
  const s = document.createElement("div");
  s.className = "screen aktiv";
  s.innerHTML = `<div class="hero-zahl"><div class="status-dot ${erg.typ}">${erg.emoji}</div><h1>${erg.titel}</h1><p>${erg.text}</p></div><button class="cta" onclick="window.print()">Drucken</button>`;
  wrap.appendChild(s);
}
</script>
</body>
</html>
